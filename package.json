  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "dev:search": "npm run build && npm run sync-search && npm run dev",
    "sync-search": "mkdir -p public/pagefind && cp -r dist/client/pagefind/* public/pagefind/",
    "lint": "astro check",
    "preview": "astro preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "E2E_COVERAGE=true playwright test --project=chromium",
    "test:e2e:coverage:report": "tsx e2e/process-coverage.ts && c8 report --reporter=text --reporter=lcov --temp-directory=./coverage/e2e"
  },
